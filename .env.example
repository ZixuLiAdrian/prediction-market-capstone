# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prediction_markets
DB_USER=postgres
DB_PASSWORD=postgres

# LLM Provider: "groq" or "gemini"
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=your-api-key-here
LLM_MAX_RETRIES=2
LLM_TIMEOUT=30

# RSS Feed URLs (comma-separated)
RSS_FEEDS=https://rss.politico.com/politics-news.xml,https://feeds.bbci.co.uk/news/world/rss.xml,https://feeds.reuters.com/reuters/topNews

# GDELT
GDELT_QUERY=prediction market OR election OR policy
GDELT_MAX_RECORDS=100

# Clustering
EMBEDDING_MODEL=all-MiniLM-L6-v2
DBSCAN_EPS=0.35
DBSCAN_MIN_SAMPLES=3
CLUSTER_MIN_MENTIONS=3

# Pipeline
BATCH_SIZE=100
LOG_LEVEL=INFO
