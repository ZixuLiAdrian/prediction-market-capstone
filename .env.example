# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prediction_markets
DB_USER=postgres
DB_PASSWORD=postgres

# LLM Provider: "groq" or "gemini"
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
FR3_LLM_MODEL=llama-3.1-8b-instant
FR4_LLM_MODEL=llama-3.1-8b-instant
RUNNER_DEFAULT_FR3_MODEL=llama-3.1-8b-instant
RUNNER_DEFAULT_FR4_MODEL=llama-3.1-8b-instant
LLM_API_KEY=your-api-key-here
LLM_MAX_RETRIES=2
LLM_RATE_LIMIT_MAX_RETRIES=-1
LLM_TIMEOUT=30
LLM_MIN_REQUEST_INTERVAL_SECONDS=2.1
LLM_RATE_LIMIT_BACKOFF_BASE_SECONDS=5.0
LLM_RATE_LIMIT_BACKOFF_MAX_SECONDS=30.0

# RSS Feed URLs (comma-separated). Defaults to 30 feeds (15 news + 15 Reddit) if not set.
# RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,...

# GDELT — defaults cover 14 domains (elections, FDA, M&A, climate, AI, NATO, earnings, space, etc.)
# GDELT_QUERY=election OR policy OR FDA OR merger OR climate OR AI OR sanctions OR NATO OR treaty OR IPO OR earnings OR trial OR space OR energy
GDELT_MAX_RECORDS=100

# Clustering
EMBEDDING_MODEL=all-MiniLM-L6-v2
DBSCAN_EPS=0.35
DBSCAN_MIN_SAMPLES=3
CLUSTER_MIN_MENTIONS=3

# Pipeline
BATCH_SIZE=100
LOG_LEVEL=INFO
LOG_MODE=normal
FR3_MAX_CLUSTERS=10
FR4_MAX_EVENTS=5
FR4_MAX_QUESTIONS_PER_STORY=2
