# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prediction_markets
DB_USER=postgres
DB_PASSWORD=postgres

# LLM Provider: "groq" or "gemini"
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=your-api-key-here
LLM_MAX_RETRIES=2
LLM_TIMEOUT=30

# RSS Feed URLs (comma-separated)
RSS_FEEDS=https://rss.politico.com/politics-news.xml,https://feeds.bbci.co.uk/news/world/rss.xml,https://feeds.reuters.com/reuters/topNews

# GDELT
GDELT_QUERY=prediction market OR election OR policy
GDELT_MAX_RECORDS=100

# Reddit (OAuth — register at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=prediction-market-pipeline/1.0
REDDIT_SUBREDDITS=politics,worldnews,news,investing,CryptoCurrency,technology,Polymarket
REDDIT_POST_LIMIT=25

# Hacker News
HN_MAX_STORIES=30

# Wikipedia Pageviews
WIKI_PAGEVIEW_THRESHOLD=10000

# Federal Register (no key required)
FED_REGISTER_QUERY=
FED_REGISTER_PER_PAGE=20

# Congress.gov (free key at https://api.congress.gov/sign-up/)
CONGRESS_API_KEY=
CONGRESS_LIMIT=20

# SEC EDGAR (no key required, but needs contact info in User-Agent)
SEC_EDGAR_USER_AGENT=prediction-market-pipeline admin@example.com
SEC_EDGAR_FORM_TYPES=8-K,4
SEC_EDGAR_LIMIT=20

# BLS (no key required for v1; free key for v2 at https://data.bls.gov/registrationEngine/)
BLS_API_KEY=
BLS_SERIES_IDS=CUUR0000SA0,LNS14000000

# FRED (free key at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=
FRED_SERIES_IDS=FEDFUNDS,T10Y2Y,UNRATE

# EIA (free key at https://www.eia.gov/opendata/)
EIA_API_KEY=
EIA_SERIES_IDS=PET.RWTC.W

# Kalshi
KALSHI_LIMIT=50

# Clustering
EMBEDDING_MODEL=all-MiniLM-L6-v2
DBSCAN_EPS=0.35
DBSCAN_MIN_SAMPLES=3
CLUSTER_MIN_MENTIONS=3
NEAR_DUPLICATE_THRESHOLD=0.92
DEFAULT_SOURCE_WEIGHT=1.0

# Pipeline
BATCH_SIZE=100
LOG_LEVEL=INFO
